{
  "name": "opencode-advisor-mcp",
  "version": "0.2.0",
  "description": "A local MCP server that lets Codex ask OpenCode for a read-only review pass or planning pass on local work.",
  "license": "MIT",
  "author": "henrydontbbai",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henrydontbbai/opencode-advisor-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/henrydontbbai/opencode-advisor-mcp/issues"
  },
  "homepage": "https://github.com/henrydontbbai/opencode-advisor-mcp#readme",
  "keywords": [
    "mcp",
    "codex",
    "opencode",
    "code-review",
    "cli",
    "local-tooling"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "opencode-advisor-mcp": "src/server.mjs",
    "opencode-advisor-agent": "bin/opencode-advisor-agent.mjs",
    "opencode-advisor-setup": "bin/opencode-advisor-setup.mjs",
    "opencode-advisor-doctor": "bin/opencode-advisor-doctor.mjs"
  },
  "files": [
    "src/",
    "agents/",
    "bin/",
    "docs/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node src/server.mjs",
    "setup": "node bin/opencode-advisor-setup.mjs",
    "doctor": "node bin/opencode-advisor-doctor.mjs",
    "print-agent": "node bin/opencode-advisor-agent.mjs",
    "smoke": "node -e \"import('./src/server.mjs').then((m) => { const env = { OPENCODE_ADVISOR_ALLOWED_ROOTS: process.cwd() }; m.createServer({ env }); if (m.parseAllowedRoots(undefined, {}).length !== 0) process.exit(1); let failed = false; try { m.createServer({ env: {} }); failed = true; } catch {} if (failed) process.exit(1); })\"",
    "test": "node scripts/run-test-files.mjs",
    "test:doctor": "node --test test/doctor.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  }
}
